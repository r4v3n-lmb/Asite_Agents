# Gendesk
GENDESK_BASE_URL=https://your-gendesk-domain.example.com
GENDESK_API_KEY=replace_me
GENDESK_EMAIL=admin@example.com
GENDESK_AUTH_HEADER=Authorization
GENDESK_AUTH_PREFIX=Bearer
GENDESK_TICKET_GET_PATH_TEMPLATE=/api/v2/tickets/{ticket_id}.json
GENDESK_TICKET_UPDATE_PATH_TEMPLATE=/api/v2/tickets/{ticket_id}.json
GENDESK_TICKET_LIST_PATH=/api/v2/tickets.json?per_page=25&sort_by=updated_at
GENDESK_TICKET_LIST_LIMIT=25

# Asite
ASITE_LOGIN_URL=https://dms.asite.com/api/login/{email}/{password}
ASITE_EMAIL=asite_user@example.com
ASITE_PASSWORD=replace_me

# Runtime
DRY_RUN=true
ASITE_API_OVERVIEW_PDF=Asite-API_Services_Overview.pdf

# Dashboard auth
DASHBOARD_SECRET_KEY=replace_with_long_random_value
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=replace_with_strong_password
DASHBOARD_USER_DB=.cache/users.db
DASHBOARD_AUDIT_LOG=.cache/dashboard_audit.jsonl
DASHBOARD_PUBLIC_BASE_URL=https://your-render-app.onrender.com

# Slack notifications
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=
SLACK_NOTIFY_DECISIONS=false
SLACK_SIGNING_SECRET=
